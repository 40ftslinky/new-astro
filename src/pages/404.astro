---
// layout
import BaseLayout from '../layouts/BaseLayout.astro';

// components
// import { Image } from "astro:assets";
import { Picture } from 'astro:assets';
import img404 from '/src/assets/imgs/404/40ftSlinky_404.svg';

// content
const uniqueID = "404";
const pageTitle = "404";
const metaTitle = "404 meta Title tbc";
const metaDescription = "404 page meta description tbc";
const pageHead = "404 - Oops";
const pageDesc = "";
const pageContent = "404 content tbc";

---

